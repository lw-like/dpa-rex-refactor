{
  "name": "dpa-rex-refacror",
  "displayName": "DPA-REX-Refacror",
  "author": "lw-like",
  "description": "Bulk find-and-replace using regex patterns across files, with saved pattern support.",
  "version": "0.1.0",
  "publisher": "dpa-rex-refacror",
  "license": "AGPL-3.0-only",
  "engines": { "vscode": "^1.85.0" },
  "categories": ["Other"],
  "repository": "https://github.com/lw-like/dpa-rex-refactor",
  "activationEvents": [
    "onCommand:dpa-rex-refacror.openPanel",
    "onCommand:dpa-rex-refacror.analyzeSelection",
    "onCommand:dpa-rex-refacror.extractAngularComponent",
    "onView:dpa-rex-refacror.sidebar"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "dpa-rex-refacror-container",
          "title": "DPA-REX-Refacror",
          "icon": "images/icon.svg"
        }
      ]
    },
    "views": {
      "dpa-rex-refacror-container": [
        {
          "id": "dpa-rex-refacror.sidebar",
          "type": "webview",
          "name": "DPA-REX-Refacror"
        }
      ]
    },
    "commands": [
      {
        "command": "dpa-rex-refacror.openPanel",
        "title": "DPA-REX-Refacror: Open Panel"
      },
      {
        "command": "dpa-rex-refacror.analyzeSelection",
        "title": "Analyze Selection — Regex Planner"
      },
      {
        "command": "dpa-rex-refacror.extractAngularComponent",
        "title": "Extract to Angular Component"
      }
    ],
    "configuration": {
      "title": "DPA-REX-Refacror",
      "properties": {
        "dpa-rex-refacror.defaultScope": {
          "type": "string",
          "enum": ["currentFile", "openFiles", "workspaceFolder", "glob"],
          "default": "workspaceFolder",
          "description": "Default scope for bulk replace operations."
        },
        "dpa-rex-refacror.excludePattern": {
          "type": "string",
          "default": "",
          "description": "Additional glob pattern to exclude from bulk replace (supports brace syntax, e.g. {**/generated/**,**/*.snap}). Common technical directories (node_modules, .git, dist, out, build, coverage, vendor, __pycache__, etc.) are always excluded."
        },
        "dpa-rex-refacror.angular.autoImport": {
          "type": "boolean",
          "default": true,
          "description": "Automatically add the extracted component to the parent component's imports array and TypeScript import statement."
        },
        "dpa-rex-refacror.angular.convertToMobileFirst": {
          "type": "boolean",
          "default": true,
          "description": "When extracted CSS uses max-width media queries, automatically reorganise it to mobile-first (min-width) order."
        },
        "dpa-rex-refacror.angular.mixinsFile": {
          "type": "string",
          "default": "",
          "description": "Workspace-relative path to a SCSS file containing breakpoint variables and @mixin definitions (e.g. 'src/styles/_mixins.scss'). When set, extracted component SCSS will use mixins instead of raw @media queries."
        },
        "dpa-rex-refacror.angular.mixinsImport": {
          "type": "string",
          "default": "",
          "description": "Import statement added at the top of generated component SCSS files when a mixins file is configured (e.g. \"@use 'app' as *\" or \"@import 'mixins'\")."
        }
      }
    },
    "keybindings": [
      {
        "command": "dpa-rex-refacror.sidebar.focus",
        "key": "ctrl+shift+r",
        "mac": "cmd+shift+r"
      },
      {
        "command": "dpa-rex-refacror.analyzeSelection",
        "key": "ctrl+shift+alt+r",
        "mac": "cmd+shift+alt+r",
        "when": "editorHasSelection"
      },
      {
        "command": "dpa-rex-refacror.extractAngularComponent",
        "key": "ctrl+shift+alt+a",
        "mac": "cmd+shift+alt+a",
        "when": "editorHasSelection"
      }
    ],
    "menus": {
      "commandPalette": [
        { "command": "dpa-rex-refacror.openPanel" },
        { "command": "dpa-rex-refacror.analyzeSelection", "when": "editorHasSelection" },
        { "command": "dpa-rex-refacror.extractAngularComponent", "when": "editorHasSelection" }
      ],
      "editor/context": [
        {
          "command": "dpa-rex-refacror.analyzeSelection",
          "when": "editorHasSelection",
          "group": "dpa-rex-refacror@1"
        },
        {
          "command": "dpa-rex-refacror.extractAngularComponent",
          "when": "editorHasSelection",
          "group": "dpa-rex-refacror@2"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts",
    "test": "node ./out/test/runTest.js"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.6",
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^6.19.0",
    "@typescript-eslint/parser": "^6.19.0",
    "@vscode/test-electron": "^2.3.8",
    "eslint": "^8.56.0",
    "glob": "^10.3.10",
    "mocha": "^10.3.0",
    "typescript": "^5.3.3"
  }
}
